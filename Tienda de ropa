using System;

class Prenda
{
    public string nombre;
    public double precio;

    public void MostrarPrenda()
    {
        Console.WriteLine("Prenda: " + nombre);
        Console.WriteLine("Precio: $" + precio);
    }
}

class Camisa : Prenda
{
    public void TipoCamisa()
    {
        Console.WriteLine("Esta es una camisa.");
    }
}

class Pantalon : Prenda
{
    public void TipoPantalon()
    {
        Console.WriteLine("Este es un pantalón.");
    }
}

class Chaqueta : Prenda
{
    public void TipoChaqueta()
    {
        Console.WriteLine("Esta es una chaqueta.");
    }
}

class Program
{
    static void Main()
    {
        Camisa camisa = new Camisa();
        camisa.nombre = "Camisa casual";
        camisa.precio = 25.50;

        camisa.MostrarPrenda();
        camisa.TipoCamisa();
    }
}
