using System;

class DiscoVinilo
{
    public string artista;
    public string album;

    public void MostrarInfo()
    {
        Console.WriteLine("Artista: " + artista);
        Console.WriteLine("Álbum: " + album);
    }
}

class DiscoRock : DiscoVinilo
{
    public void ReproducirRock()
    {
        Console.WriteLine("Reproduciendo disco de rock...");
    }
}

class DiscoJazz : DiscoVinilo
{
    public void ReproducirJazz()
    {
        Console.WriteLine("Reproduciendo disco de jazz...");
    }
}

class DiscoPop : DiscoVinilo
{
    public void ReproducirPop()
    {
        Console.WriteLine("Reproduciendo disco de pop...");
    }
}

class Program
{
    static void Main()
    {
        DiscoRock rock = new DiscoRock();
        rock.artista = "Queen";
        rock.album = "A Night at the Opera";
        rock.MostrarInfo();
        rock.ReproducirRock();
    }
}
