using System;

class Pizza
{
    public string tamaño;

    public void Preparar()
    {
        Console.WriteLine("Preparando pizza tamaño " + tamaño);
    }
}

class PizzaPepperoni : Pizza
{
    public void AgregarPepperoni()
    {
        Console.WriteLine("Agregando pepperoni.");
    }
}

class PizzaHawaiana : Pizza
{
    public void AgregarPina()
    {
        Console.WriteLine("Agregando piña y jamón.");
    }
}

class PizzaVegetariana : Pizza
{
    public void AgregarVegetales()
    {
        Console.WriteLine("Agregando vegetales.");
    }
}

class Program
{
    static void Main()
    {
        PizzaHawaiana pizza = new PizzaHawaiana();
        pizza.tamaño = "Grande";

        pizza.Preparar();
        pizza.AgregarPina();
    }
}
